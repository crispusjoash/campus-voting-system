# PostgreSQL connection (provided by Render DB when linked)
DATABASE_URL=postgresql://user:password@host:5432/campus_voting_db

# OR individual vars (used locally)
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campus_voting_db

# App Config
JWT_SECRET=change_this_to_a_long_random_string
PORT=5000

# CORS – set to your Render/Vercel frontend URL in production
FRONTEND_URL=https://mmust-voting-frontend.onrender.com

# Email (Gmail App Password)
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_16char_app_password
